# NextAuth 配置
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare Turnstile 验证
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITEKEY="your_turnstile_site_key"
CLOUDFLARE_TURNSTILE_SECRETKEY="your_turnstile_secret_key"

# Cloudflare AI 配置
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"

# 添加高德地图API密钥
NEXT_PUBLIC_AMAP_API_KEY="your_amap_api_key_here"

# 添加 Mapbox Token
NEXT_PUBLIC_MAPBOX_TOKEN="your_mapbox_token_here"

# OpenAI / LangGraph Agent 配置
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="your_openai_api_key"
CHAT_MODEL="qwen-flash"
LANGGRAPH_MODEL="qwen-flash"
